---
import { getImage } from 'astro:assets';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/galleryImages/*.{jpeg,jpg,png,gif}',
  { eager: true }
);

const MAX_LONG_SIDE_THUMB = 450;
const MAX_LONG_SIDE_FULL = 1000;

const thumbnails = await Promise.all(
  Object.entries(images).map(async ([path, image]) => {
    const filename =
      path.split('/').pop()?.split('.')[0]?.replace(/[-_]/g, ' ') || 'Galeriebild';
    const altText = filename.charAt(0).toUpperCase() + filename.slice(1);

    const srcMeta = image.default;
    const isLandscape = srcMeta.width >= srcMeta.height;

    const thumbOpts = {
      src: srcMeta,
      format: 'webp',
      ...(isLandscape ? { width: MAX_LONG_SIDE_THUMB } : { height: MAX_LONG_SIDE_THUMB }),
    };

    const fullOpts = {
      src: srcMeta,
      format: 'webp',
      ...(isLandscape ? { width: MAX_LONG_SIDE_FULL } : { height: MAX_LONG_SIDE_FULL }),
    };

    const thumbResult = await getImage(thumbOpts);
    const fullResult = await getImage(fullOpts);

    return {
      thumb: thumbResult.src,
      fullsize: fullResult.src,
      alt: altText,
      ratio: srcMeta.width / srcMeta.height,
    };
  })
);
---

<section class="portfolio">
  <div class="portfolio-container" id="portfolio-container">
    {thumbnails.map((image, index) => (
      <div
        class="portfolio-item"
        data-index={index}
        data-fullsize={image.fullsize}
        data-ratio={image.ratio}
      >
        <img
          src={image.thumb}
          alt={image.alt}
          loading={index < 4 ? 'eager' : 'lazy'}
          decoding="async"
        />
      </div>
    ))}
  </div>
</section>

<style>
  .portfolio {
    position: relative;
    overflow: hidden;
    padding: 2rem 0;
  }

  .portfolio-container {
    position: relative;
    width: 100%;
    min-height: 220vh;
  }

  .portfolio-item {
    position: absolute;
    left: var(--x, 0px);
    top: var(--y, 0px);
    width: var(--w, 260px);
    height: var(--h, 180px);
    will-change: transform;
  }

  .portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const container = document.getElementById('portfolio-container');
  const items = Array.from(
    document.querySelectorAll<HTMLDivElement>('.portfolio-item')
  );

  function placeItems() {
    if (!container || items.length === 0) return;

    // Breakpoints based on window width
    const vw = window.innerWidth;
    // Number of columns based on window width
    const cols = vw >= 1191 ? 3 : 2;
    // Gap between items based on window width
    const gap = vw >= 1191 ? 96 : 64;
    // Padding on the left and right of the container based on window width
    const padX = vw >= 1191 ? 96 : 40;
    const padY = vw >= 1191 ? 96 : 40;

    const containerW = container.clientWidth;
    const cellW = (containerW - padX * 2 - gap * (cols - 1)) / cols;
    const targetLong = Math.min(450, cellW * 0.9);

    const cursorYByCol = Array(cols).fill(padY);

    items.forEach((item, index) => {
      const ratio = Number(item.dataset.ratio || 1);
      const isLandscape = ratio >= 1;

      const w = isLandscape ? targetLong : targetLong * ratio;
      const h = isLandscape ? targetLong / ratio : targetLong;

      const col = index % cols;
      const baseX = padX + col * (cellW + gap);

      const safeMaxX = Math.max(0, cellW - w);
      const scatterX = Math.random() * safeMaxX;

      const x = baseX + scatterX;
      const y = cursorYByCol[col];

      item.style.setProperty('--x', `${x}px`);
      item.style.setProperty('--y', `${y}px`);
      item.style.setProperty('--w', `${w}px`);
      item.style.setProperty('--h', `${h}px`);

      cursorYByCol[col] = y + h + gap + Math.random() * 150;
      item.dataset.speed = String(((Math.random() * 3) + 2).toFixed(2));
    });

    const maxY = Math.max(...cursorYByCol) + padY;
    container.style.minHeight = `${maxY}px`;

    ScrollTrigger.getAll().forEach((trigger) => trigger.kill());

    items.forEach((item) => {
      gsap.from(item, {
        y: () => Math.random() * 300 + 150 + 'px',
        ease: 'none',
        scrollTrigger: {
          trigger: item,
          start: 'top 100%',
          end: 'bottom 20%',
            scrub: true,
          },
        })
    });

    // items.forEach((item) => {
    //   const speed = Number(item.dataset.speed || 0);
    //   gsap.fromTo(item, {
    //     y: 0,
    //   }, {
    //     y: speed * 120,
    //     ease: 'none',
    //     scrollTrigger: {
    //       trigger: item,
    //       start: 'top bottom',
    //       end: 'bottom top',
    //       scrub: true,
    //     },
    //   });
    // });
  }

  placeItems();
  window.addEventListener('resize', placeItems);
</script>
