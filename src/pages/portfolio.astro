---
import BaseLayout from '../Layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';


const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/galleryImages/*.{jpeg,jpg,png,gif}',
  { eager: true }
);

const MAX_LONG_SIDE_THUMB = 450;
const MAX_LONG_SIDE_FULL = 1000;

const thumbnails = await Promise.all(
  Object.entries(images).map(async ([path, image]) => {
    const filename =
      path.split('/').pop()?.split('.')[0]?.replace(/[-_]/g, ' ') || 'Galeriebild';
    const altText = filename.charAt(0).toUpperCase() + filename.slice(1);

    const srcMeta = image.default;
    const isLandscape = srcMeta.width >= srcMeta.height;

    const thumbOpts = {
      src: srcMeta,
      format: 'webp',
      ...(isLandscape ? { width: MAX_LONG_SIDE_THUMB } : { height: MAX_LONG_SIDE_THUMB }),
    };

    const fullOpts = {
      src: srcMeta,
      format: 'webp',
      ...(isLandscape ? { width: MAX_LONG_SIDE_FULL } : { height: MAX_LONG_SIDE_FULL }),
    };

    const thumbResult = await getImage(thumbOpts);
    const fullResult = await getImage(fullOpts);

    return {
      thumb: thumbResult.src,
      fullsize: fullResult.src,
      alt: altText,
      ratio: srcMeta.width / srcMeta.height,
    };
  })
);
---

<html lang="de">
	<head>
		<meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Eventfotografie, Businessportraits & Reportagen in Berlin - Fotograf für Firmenfeiern, Messen, Magazine. Erfahrung für authentische Momente.">
    <meta name="keywords" content="Eventfotografie Berlin, Businessportraits, Reportagefotografie, Firmenfeier Fotograf, Messefotografie, Unternehmensfotografie">
    <meta name="author" content="Marco Baaß">
    <title>Eventfotografie & Businessportraits in Berlin | Marco Baaß</title>
    <meta property="og:title" content="Eventfotografie & Businessportraits in Berlin | Marco Baaß">
    <meta property="og:description" content="Professionelle Fotografie für Firmenfeiern, Messen & Businessportraits. Authentisch & ausdrucksstark.">
    <!-- <meta property="og:image" content="https://deinewebsite.de/images/vorschaubild.jpg"> -->
    <!-- <meta property="og:url" content="https://deinewebsite.de"> -->
    <meta property="og:type" content="website">
    <link rel="icon" href="/favicon.png">
    <link rel="canonical" href="https://www.baass-fotografie.de/" />
	</head>
	<body>
    <BaseLayout>
      <section class="portfolio">
        <div class="portfolio-container" id="portfolio-container">
          {thumbnails.map((image, index) => (
            <div
              class="portfolio-item"
              data-index={index}
              data-fullsize={image.fullsize}
              data-ratio={image.ratio}
            >
              <img
                src={image.thumb}
                alt={image.alt}
                loading={index < 4 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}
        </div>
      </section>
    </BaseLayout>
  </body>

<style>

  .portfolio {
    position: relative;
    overflow: visible;
    padding: 7rem 0;
  }

  .portfolio-container {
    --cols: 1;
    --col-gap: 0px;
    --row-gap: 0px;
    --pad-x: 10px;
    --pad-y: 10px;
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    column-gap: var(--col-gap);
    padding: var(--pad-y) var(--pad-x) calc(var(--pad-y) + 120px) var(--pad-x);
    align-items: start;
    width: 100%;
  }

  .portfolio-col {
    position: relative;
    z-index: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    will-change: transform;
  }

  .portfolio-col:has(.portfolio-item:hover) {
    z-index: 1000;
  }

  .portfolio-item {
    display: block;
    position: relative;
    width: var(--w, 260px);
    height: var(--h, 180px);
    margin-inline: auto;    
    opacity: 0.75;
    transition: transform 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }

  .portfolio-item:hover {
      transform: scale(1.1);
      opacity: 1;
      z-index: 1000;
  }

  .portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }

</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const container = document.getElementById('portfolio-container');
  const items = Array.from(
    document.querySelectorAll<HTMLDivElement>('.portfolio-item')
  );
  let columnTweens: gsap.core.Tween[] = [];

  function placeItems() {
    if (!container || items.length === 0) return;

    // Breakpoints based on window width
    const vw = window.innerWidth;
    // Number of columns based on window width
    let cols = 1;
    if (vw >= 1280) {
      cols = 3;
    } else if (vw >= 848) {
      cols = 2;
    } else {
      cols = 1;
    }

    // Gap between items based on window width
    let colGap = 24;
    let rowGap = 48;
    let padX = 20;
    let padY = 20;
    if (vw >= 1280) {
      colGap = 96;
      rowGap = 80;
      padX = 48;
      padY = 48;
    } else if (vw >= 848) {
      colGap = 64;
      rowGap = 56;
      padX = 32;
      padY = 32;
    } 

    container.style.setProperty('--cols', String(cols));
    container.style.setProperty('--col-gap', `${colGap}px`);
    container.style.setProperty('--row-gap', `${rowGap}px`);
    container.style.setProperty('--pad-x', `${padX}px`);
    container.style.setProperty('--pad-y', `${padY}px`);

    container.replaceChildren();

    const colEls = Array.from({ length: cols }, (_, col) => {
      const colEl = document.createElement('div');
      colEl.className = 'portfolio-col';
      colEl.dataset.col = String(col);
      container.appendChild(colEl);
      return colEl;
    });

    const containerW = container.clientWidth;
    const cellW = Math.max(0, (containerW - padX * 2 - colGap * (cols - 1)) / cols);
    const targetLong = Math.min(450, cellW * 0.9);

    const itemCountByCol = Array(cols).fill(0);

    items.forEach((item, index) => {
      const ratio = Number(item.dataset.ratio || 1);
      const isLandscape = ratio >= 1;

      const w = isLandscape ? targetLong : targetLong * ratio;
      const h = isLandscape ? targetLong / ratio : targetLong;

      item.style.setProperty('--w', `${w}px`);
      item.style.setProperty('--h', `${h}px`);

      const col = index % cols;
      item.dataset.col = String(col);
      item.style.marginTop = itemCountByCol[col] === 0 ? '0px' : `${rowGap}px`;
      colEls[col].appendChild(item);
      itemCountByCol[col] += 1;
    });

    columnTweens.forEach((tween) => tween.kill());
    columnTweens = [];

    colEls.forEach((colEl) => {
      const col = Number(colEl.dataset.col || 0);
      const fromY = col % 2 === 0 ? 160 : -160;

      gsap.set(colEl, { y: 0 });

      const tween = gsap.to(colEl, {
        y: fromY,
        ease: 'none',
        scrollTrigger: {
          trigger: container,
          start: 'top 50%',
          end: 'bottom 100%',
          scrub: 1.5,
          invalidateOnRefresh: true,
        },
      });

      columnTweens.push(tween);
    });

    ScrollTrigger.refresh();
  }

  placeItems();
  let resizeRaf: number | undefined;
  window.addEventListener('resize', () => {
    if (resizeRaf) cancelAnimationFrame(resizeRaf);
    resizeRaf = requestAnimationFrame(placeItems);
  });

</script>
